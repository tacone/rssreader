{
	"name": "rssreader",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"// dev:portless is broken": "See https://github.com/vercel-labs/portless/pull/303",
		"dev:portless": "portless rssreader bun run dev --clearScreen false",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"feeds:fetch": "bun run src/lib/server/feed/cli.ts",
		"feeds:refresh-all": "bun run src/lib/server/feed/refresh-all.ts",
		"seeds:create": "bun run src/lib/server/seed/create-user.ts"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/dompurify": "^3.2.0",
		"@types/he": "^1.2.3",
		"@types/jsdom": "^28.0.3",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"better-auth": "~1.4.21",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"playwright": "^1.60.0",
		"portless": "^0.14.0",
		"postgres": "^3.4.9",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"daisyui": "^5.5.20",
		"dompurify": "^3.4.8",
		"dotenv": "^17.4.2",
		"feedsmith": "^2.9.4",
		"he": "^1.2.0",
		"jsdom": "^29.1.1"
	}
}
